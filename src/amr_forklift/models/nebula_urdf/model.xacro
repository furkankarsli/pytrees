<?xml version="1.0"?>
<robot name="nebula" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Simülasyon/Gerçek mod seçimi -->
  <xacro:arg name="is_sim" default="false"/>
  <xacro:include filename="$(find amr_forklift)/models/nebula_urdf/properties.xacro"/>

  <!-- BASE PROPERTIES -->
  <xacro:property name="base_weight" value="30.0"/>
  <xacro:property name="base_length" value="0.797"/>
  <xacro:property name="base_width" value="0.494"/>
  <xacro:property name="base_height" value="0.201"/>

  <!-- WHEEL PROPERTIES -->
  <!-- 2.0 kg gerçekçi (eski 10.0 kg absürt → aşırı dönme eylemsizliği →
       patinaj + durunca kayma. Eylemsizlik 5 kat azaldı.) -->
  <xacro:property name="wheel_weight" value="2.0"/>
  <xacro:property name="wheel_radius" value="0.075"/>
  <xacro:property name="wheel_length" value="0.045"/>

  <!-- BASE FOOTPRINT -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.125" rpy="0 0 0"/>
  </joint>

  <!-- BASE LINK -->
  <link name="base_link">
    <!-- ... inertia, visual, collision ... -->
    <xacro:box_inertia m="${base_weight}" l="${base_length}" w="${base_width}" h="${base_height}"
                         xyz="0 0 0" rpy="0 0 0"/>
    <visual>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="green"><color rgba="0.0 0.7 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
  </link>

  <!-- ÖN İŞARETİ — robotun ileri (+X) yönünü belirtir. Beyaz dikey çubuk. -->
  <link name="front_marker_link">
    <visual>
      <geometry><box size="0.02 0.15 0.12"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
  </link>
  <joint name="front_marker_joint" type="fixed">
    <parent link="base_link"/>
    <!-- Gövde ön yüzü x=+0.3985; işareti tam öne, biraz dışına yapıştır -->
    <origin xyz="0.405 0 0.05" rpy="0 0 0"/>
    <child link="front_marker_link"/>
  </joint>

  <!-- YAN PANEL — sol yüze (+Y) "SIRIUS" yazılı doku -->
  <material name="nebula_label">
    <texture filename="package://amr_forklift/models/nebula_urdf/materials/textures/nebula_label.png"/>
  </material>
  <link name="left_panel_link">
    <visual>
      <geometry><box size="0.6 0.01 0.15"/></geometry>
      <material name="nebula_label"/>
    </visual>
  </link>
  <joint name="left_panel_joint" type="fixed">
    <parent link="base_link"/>
    <!-- Sol yüz y=+0.247; paneli biraz dışına yapıştır -->
    <origin xyz="0 0.249 0.0" rpy="0 0 0"/>
    <child link="left_panel_link"/>
  </joint>

  <!-- WHEEL MACRO -->
  <xacro:macro name="Wheel_Link" params="name x y z w">
    <link name="${name}_link">
      <xacro:cylinder_inertia m="${wheel_weight}" r="${wheel_radius}" h="${wheel_length}" xyz="0 0 0" rpy="0 0 0"/>
      <visual>
        <origin rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}"/></geometry>
        <material name="red"><color rgba="0.75 0 0 1"/></material>
      </visual>
      <collision>
        <origin rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}"/></geometry>
      </collision>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/> <!-- Standart eksen -->
      <!-- Damping + friction: robot dururken tekerlek serbest dönmesin -->
      <dynamics damping="1.0" friction="1.0"/>
    </joint>
  </xacro:macro>

  <!-- CASTER WHEEL MACRO — gerçek dönen sarhoş teker (swivel + roll) -->
  <!-- z = swivel gövdesinin base_link'e göre yüksekliği.
       Tekerlek merkezi z-0.045, yarıçap 0.03 → zemin teması z-0.075.
       z=-0.05 verince zemin teması -0.125 = tahrik tekerleğiyle aynı. -->
  <xacro:macro name="Caster_Wheel" params="name x y z">
    <!-- Swivel gövdesi: dikey eksende serbest döner, yönünü kendi bulur -->
    <link name="${name}_mount_link">
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
      </inertial>
    </link>
    <joint name="${name}_swivel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_mount_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.02" friction="0.0"/>
    </joint>

    <!-- Caster tekerleği: yatay eksende yuvarlanır.
         -0.025 trailing offset → robot hareket edince kendini hizalar. -->
    <link name="${name}_link">
      <visual>
        <origin rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="0.03" length="0.02"/></geometry>
        <material name="white"><color rgba="1 1 1 1"/></material>
      </visual>
      <collision>
        <origin rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="0.03" length="0.02"/></geometry>
      </collision>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
      </inertial>
    </link>
    <joint name="${name}_roll_joint" type="continuous">
      <parent link="${name}_mount_link"/>
      <child link="${name}_link"/>
      <origin xyz="-0.025 0 -0.045" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.001" friction="0.0"/>
    </joint>
  </xacro:macro>

  <!-- WHEELS (Eksenler 1 yapıldı) -->
  <xacro:Wheel_Link name="left_wheel" x="0" y="0.2075" z="-0.05" w="1"/>
  <xacro:Wheel_Link name="right_wheel" x="0" y="-0.2075" z="-0.05" w="1"/>
  
  <!-- CASTER WHEELS — gerçek dönen sarhoş tekerler.
       z=-0.05: swivel mount yüksekliği. Tekerlek zemin teması -0.125 =
       tahrik tekerleğiyle aynı seviye. Yuvarlanan teker kaymaz, sürüklemez. -->
  <xacro:Caster_Wheel name="caster_fl" x="0.35" y="0.22" z="-0.05"/>
  <xacro:Caster_Wheel name="caster_fr" x="0.35" y="-0.22" z="-0.05"/>
  <xacro:Caster_Wheel name="caster_bl" x="-0.35" y="0.22" z="-0.05"/>
  <xacro:Caster_Wheel name="caster_br" x="-0.35" y="-0.22" z="-0.05"/>

  <!-- LIDAR MACRO -->
  <xacro:macro name="LIDAR" params="x y z">
    <link name="lidar_link">
      <xacro:cylinder_inertia m="0.02" r="0.04" h="0.04" xyz="0 0 0" rpy="0 0 0"/>
      <visual>
        <geometry><cylinder radius="0.04" length="0.04"/></geometry>
        <material name="gray"><color rgba="0.7 0.7 0.7 1"/></material>
      </visual>
      <collision>
        <geometry><cylinder radius="0.04" length="0.04"/></geometry>
      </collision>
    </link>
    <joint name="lidar_joint" type="fixed">
      <parent link="base_link"/>
      <child link="lidar_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- IMU MACRO -->
  <xacro:macro name="IMU" params="x y z">
    <link name="imu_link">
      <xacro:box_inertia m="0.01" l="0.01" w="0.01" h="0.01" xyz="0 0 0" rpy="0 0 0"/>
      <visual>
        <geometry><box size="0.01 0.01 0.01"/></geometry>
        <material name="gray"><color rgba="0.7 0.7 0.7 1"/></material>
      </visual>
      <collision>
        <geometry><box size="0.01 0.01 0.01"/></geometry>
      </collision>
    </link>
    <joint name="imu_joint" type="fixed">
      <parent link="base_link"/>
      <child link="imu_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- SENSORS (Positions) -->
  <xacro:LIDAR x="0" y="0" z="0.2"/>
  <xacro:IMU x="0" y="0" z="0.09"/>

  <!-- DISTANCE SENSOR MACRO -->
  <xacro:macro name="DISTANCE_SENSOR" params="name x y z">
    <link name="${name}_link">
      <xacro:box_inertia m="0.01" l="0.02" w="0.02" h="0.02" xyz="0 0 0" rpy="0 0 0"/>
      <visual>
        <geometry><box size="0.02 0.02 0.02"/></geometry>
        <material name="white"><color rgba="1 1 1 1"/></material>
      </visual>
      <collision>
        <geometry><box size="0.02 0.02 0.02"/></geometry>
      </collision>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- Front Distance Sensors (placed in front of the left/right columns) -->
  <xacro:DISTANCE_SENSOR name="left_sensor" x="0.431" y="0.12" z="0.2"/>
  <xacro:DISTANCE_SENSOR name="right_sensor" x="0.431" y="-0.12" z="0.2"/>

  <!-- ============================================================ -->
  <!-- FORKLİFT KALDIRMA MEKANİZMASI (DETACHABLE / AYRILABİLİR) -->
  <!-- ============================================================ -->

  <!-- Forklift Ana Dikey Gövde (Mast) -->
  <link name="forklift_mast_link">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0.41 0 0.2" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.05"/>
    </inertial>

    <!-- Sol Dikey Sütun -->
    <visual>
      <origin xyz="0.41 0.12 0.2" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.6"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.41 0.12 0.2" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.6"/></geometry>
    </collision>

    <!-- Sağ Dikey Sütun -->
    <visual>
      <origin xyz="0.41 -0.12 0.2" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.6"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.41 -0.12 0.2" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.6"/></geometry>
    </collision>

    <!-- Üst Bağlantı Plakası -->
    <visual>
      <origin xyz="0.41 0 0.48" rpy="0 0 0"/>
      <geometry><box size="0.04 0.28 0.04"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>

    <!-- Alt Bağlantı Plakası -->
    <visual>
      <origin xyz="0.41 0 -0.08" rpy="0 0 0"/>
      <geometry><box size="0.04 0.28 0.04"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>

    <!-- Yan Montaj Braketi -->
    <visual>
      <origin xyz="0.38 0 0.08" rpy="0 0 0"/>
      <geometry><box size="0.04 0.2 0.15"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>

    <!-- Alt Destek Tekerlekleri -->
    <visual>
      <origin xyz="0.43 0.15 -0.085" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.04" length="0.02"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <visual>
      <origin xyz="0.43 -0.15 -0.085" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="0.04" length="0.02"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
  </link>

  <!-- Ayrılabilir Mekanik Bağlantı (Coupling Joint) -->
  <joint name="forklift_coupling_joint" type="fixed">
    <parent link="base_link"/>
    <child link="forklift_mast_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Hareketli Fork Taşıyıcı ve Çatal Kolları -->
  <link name="forklift_carriage_link">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0.5 0 -0.04" rpy="0 0 0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>

    <!-- Taşıyıcı Ayna Plakası -->
    <visual>
      <origin xyz="0.44 0 0.0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.35 0.1"/></geometry>
      <material name="green"><color rgba="0.0 0.7 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.44 0 0.0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.35 0.1"/></geometry>
    </collision>

    <!-- Sol Çatal Kolu (Genişlik 150mm = 0.15m, Uzunluk 350mm = 0.35m, Ara boşluk 150mm) -->
    <visual>
      <origin xyz="0.615 0.15 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.35 0.15 0.015"/></geometry>
      <material name="green"><color rgba="0.0 0.7 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.615 0.15 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.35 0.15 0.015"/></geometry>
    </collision>

    <!-- Sağ Çatal Kolu -->
    <visual>
      <origin xyz="0.615 -0.15 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.35 0.15 0.015"/></geometry>
      <material name="green"><color rgba="0.0 0.7 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.615 -0.15 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.35 0.15 0.015"/></geometry>
    </collision>
  </link>

  <joint name="lift_joint" type="prismatic">
    <parent link="forklift_mast_link"/>
    <child link="forklift_carriage_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.02" upper="0.3" effort="100.0" velocity="0.1"/>
    <dynamics damping="10.0" friction="5.0"/>
  </joint>

  <!-- Simülasyonda: Gazebo eklentilerini yükle -->
  <xacro:if value="$(arg is_sim)">
    <xacro:include filename="$(find amr_forklift)/models/nebula_urdf/gazebo_plugins.xacro"/>
  </xacro:if>

</robot>
